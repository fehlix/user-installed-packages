# Parse CLI commands and options before GUI startup
_args=("$@")
_i=0
while (( _i < ${#_args[@]} )); do
    case "${_args[$_i]}" in
        --version|-v) echo "$UIP_VERSION"; exit 0 ;;
        --generate|-g) _UIP_CLI_CMD="create";  (( _i++ )) ;;
        --install|-i)  _UIP_CLI_CMD="install"; (( _i++ )) ;;
        --help|-h)     _UIP_CLI_CMD="help";    (( _i++ )) ;;
        -f|--file)
            (( _i++ ))
            _UIP_CLI_FILE="${_args[$_i]:-}"
            [ -z "$_UIP_CLI_FILE" ] && { echo "Option --file requires an argument." >&2; exit 1; }
            (( _i++ )) ;;
        -o|--output)
            (( _i++ ))
            _UIP_CLI_OUTDIR="${_args[$_i]:-}"
            [ -z "$_UIP_CLI_OUTDIR" ] && { echo "Option --output requires an argument." >&2; exit 1; }
            (( _i++ )) ;;
        --cli|-c)      _UIP_FORCE_CLI=true; (( _i++ )) ;;
        --) (( _i++ )); break ;;
        -*) (( _i++ )) ;;  # unknown options passed through to GUI main()
        *)  break ;;
    esac
done
unset _args _i

$_UIP_FORCE_CLI && UIP_GUI=false

# If launched from / (desktop entry with no Path= set), fall back to home.
