# Wrapper: sanitize bad chars from translated strings so they are safe
# to embed in terminal command strings (bash -c).
#
# Removed chars (stripped entirely):
#   \x24  $   dollar sign     -- shell variable expansion
#   \x60  `   backtick        -- command substitution
#         |   pipe            -- command chaining
#         >   greater-than    -- output redirection
#         <   less-than       -- input redirection
#         &   ampersand       -- background / command separator
#
# Replaced chars (kept visible, made shell-safe):
#   \x27  '   ASCII single quote  ->  \xe2\x80\x99  '  right single curly quote (U+2019)
#   \x22  "   ASCII double quote  ->  \xe2\x80\x9d  "  right double curly quote (U+201D)
gettext() {
    local _s _rsq=$'\xe2\x80\x99' _rdq=$'\xe2\x80\x9d'
    _s=$(/usr/bin/gettext "$@")
    _s=${_s//[$'\x24\x60'|><&]/}
    _s=${_s//$'\x27'/$_rsq}
    _s=${_s//$'\x22'/$_rdq}
    printf '%s' "$_s"
}
ngettext() {
    local _s _rsq=$'\xe2\x80\x99' _rdq=$'\xe2\x80\x9d'
    _s=$(/usr/bin/ngettext "$@")
    _s=${_s//[$'\x24\x60'|><&]/}
    _s=${_s//$'\x27'/$_rsq}
    _s=${_s//$'\x22'/$_rdq}
    printf '%s' "$_s"
}
